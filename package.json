{
  "name": "crud-api",
  "version": "1.0.0",
  "description": "Simple CRUD API",
  "main": "./dist/index.js",
  "scripts": {
    "start:dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YaroslavaGD/node-crud-api.git"
  },
  "author": "YaroslavaGD",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/YaroslavaGD/node-crud-api/issues"
  },
  "homepage": "https://github.com/YaroslavaGD/node-crud-api#readme",
  "dependencies": {
    "dotenv": "^16.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.14",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-node": "^4.1.0",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
